{
  "name": "@aurobore/svelte",
  "version": "0.0.3",
  "description": "Svelte stores for Aurobore lifecycle and bridge events",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
