{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aurobore.dev/schema/aurobore.config.schema.json",
  "title": "Aurobore Project Config",
  "type": "object",
  "required": ["configVersion", "app", "web"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "configVersion": {
      "type": "integer",
      "const": 1
    },
    "app": {
      "type": "object",
      "required": ["id", "name", "version"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
        },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.-]+)?(\\+[\\w.-]+)?$" },
        "orientation": { "type": "string", "enum": ["portrait", "landscape", "auto"] },
        "icon": { "type": "string" },
        "iconMode": { "type": "string", "enum": ["Scale", "Crop"] },
        "splash": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "image": { "type": "string" },
            "background": { "type": "string", "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$" },
            "gradientStart": { "type": "string", "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$" },
            "gradientEnd": { "type": "string", "pattern": "^#([0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$" },
            "showName": { "type": "boolean" },
            "timeoutMs": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "web": {
      "type": "object",
      "required": ["root", "entry"],
      "additionalProperties": false,
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "entry": { "type": "string", "minLength": 1 },
        "entryUrl": { "type": "string" },
        "devServer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "host": { "type": "string" }
          }
        },
        "allowedOrigins": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^https://[^/]+"
          },
          "uniqueItems": true
        },
        "polyfills": {
          "oneOf": [
            { "type": "boolean", "const": true },
            {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["geolocation", "share", "notification", "clipboard", "mediaDevices"]
              },
              "uniqueItems": true
            }
          ]
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "plugins": {
      "type": "array",
      "items": { "type": "string" }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "engine": { "type": "string", "enum": ["chromium"] },
        "minOs": { "type": "string" },
        "targets": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "deepLinks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schemes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "cover": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["template", "preview"] },
        "actions": {
          "type": "array",
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$" },
              "label": { "type": "string", "minLength": 1 },
              "icon": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "updates": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "url": { "type": "string", "minLength": 1 },
        "channel": { "type": "string", "minLength": 1 },
        "publicKey": { "type": "string", "minLength": 1 },
        "checkOnResume": { "type": "boolean" },
        "checkIntervalMs": { "type": "integer", "minimum": 60000 }
      }
    }
  }
}
