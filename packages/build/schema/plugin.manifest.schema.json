{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aurobore.dev/schema/plugin.manifest.schema.json",
  "title": "Aurobore Plugin Manifest",
  "type": "object",
  "required": ["manifestVersion", "name", "display", "version", "engineCompat", "methods"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "manifestVersion": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "display": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.-]+)?(\\+[\\w.-]+)?$"
    },
    "engineCompat": {
      "type": "object",
      "required": ["runtime", "bridgeProtocol"],
      "additionalProperties": false,
      "properties": {
        "runtime": { "type": "string", "minLength": 1 },
        "bridgeProtocol": { "type": "integer", "minimum": 1 }
      }
    },
    "auroraCompat": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minOs": { "type": "string" },
        "engines": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scopes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nativeDeps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rpm": {
          "type": "array",
          "items": { "type": "string" }
        },
        "qt": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "types": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },
    "methods": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "args": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            ]
          },
          "result": { "type": "string" },
          "stream": { "type": "boolean" }
        }
      }
    },
    "events": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": { "type": "string" }
      }
    },
    "errors": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["message"],
        "additionalProperties": false,
        "properties": {
          "message": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      },
      "propertyNames": {
        "pattern": "^[A-Z][A-Z0-9_]*$"
      }
    }
  }
}
