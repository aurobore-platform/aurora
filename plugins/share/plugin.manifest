{
  "manifestVersion": 1,
  "name": "share",
  "display": "Share",
  "version": "1.0.0",
  "engineCompat": { "runtime": ">=0.1.0", "bridgeProtocol": 1 },
  "permissions": [],
  "nativeDeps": {
    "rpm": ["sailfish-components-share-qt5"]
  },
  "types": {
    "ShareTextArgs": {
      "text": "string",
      "title": "string?"
    },
    "ShareUrlArgs": {
      "url": "string",
      "title": "string?"
    },
    "ShareFileArgs": {
      "kind": "string",
      "url": "string",
      "mimeType": "string?",
      "title": "string?"
    }
  },
  "methods": {
    "shareText": { "args": "ShareTextArgs", "result": "void" },
    "shareUrl": { "args": "ShareUrlArgs", "result": "void" },
    "shareFile": { "args": "ShareFileArgs", "result": "void" }
  },
  "errors": {
    "SHARE_UNAVAILABLE": {
      "message": "share sheet not available",
      "description": "Нет Share API, пустые args, файл не найден, параллельный вызов"
    },
    "SHARE_CANCELLED": {
      "message": "user cancelled",
      "description": "Пользователь отменил шаринг (UI-итерация)"
    }
  }
}
