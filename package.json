{
  "name": "aurobore",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Открытая платформа для WebView-приложений под ОС Аврора (мост + плагины + CLI).",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "doctor": "pnpm --filter @aurobore/cli exec aurobore doctor",
    "poc:sync": "node tools/aurora/poc.mjs sync",
    "poc:build": "node tools/aurora/poc.mjs build",
    "poc:deploy": "node tools/aurora/poc.mjs deploy",
    "poc:run": "node tools/aurora/poc.mjs run",
    "poc:emulator": "node tools/aurora/poc.mjs emulator",
    "poc:all": "node tools/aurora/poc.mjs all",
    "container:sync": "node tools/aurora/poc.mjs sync container",
    "container:build": "node tools/aurora/poc.mjs build container",
    "container:deploy": "node tools/aurora/poc.mjs deploy container",
    "container:run": "node tools/aurora/poc.mjs run container",
    "container:emulator": "node tools/aurora/poc.mjs emulator container",
    "container:all": "node tools/aurora/poc.mjs all container"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
