{
  "name": "aurobore",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "description": "Открытая платформа для WebView-приложений под ОС Аврора (мост + плагины + CLI).",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "doctor": "pnpm --filter @aurobore/build build && pnpm --filter @aurobore/cli build && node packages/cli/dist/cli.js doctor",
    "codegen:plugins": "pnpm --filter @aurobore/build build && node packages/build/scripts/codegen-plugins.mjs",
    "poc:sync": "node tools/aurora/poc.mjs sync",
    "poc:build": "node tools/aurora/poc.mjs build",
    "poc:deploy": "node tools/aurora/poc.mjs deploy",
    "poc:run": "node tools/aurora/poc.mjs run",
    "poc:emulator": "node tools/aurora/poc.mjs emulator",
    "poc:all": "node tools/aurora/poc.mjs all",
    "container:sync": "node tools/aurora/poc.mjs sync container",
    "container:build": "node tools/aurora/poc.mjs build container",
    "container:deploy": "node tools/aurora/poc.mjs deploy container",
    "container:run": "node tools/aurora/poc.mjs run container",
    "container:emulator": "node tools/aurora/poc.mjs emulator container",
    "container:all": "node tools/aurora/poc.mjs all container",
    "container:journal": "node tools/aurora/native-debug.mjs journal",
    "container:logs": "node tools/aurora/native-debug.mjs logs",
    "container:stop": "node tools/aurora/native-debug.mjs stop",
    "container:ssh": "node tools/aurora/native-debug.mjs ssh",
    "container:restart": "node tools/aurora/native-debug.mjs restart",
    "container:valgrind": "node tools/aurora/native-debug.mjs valgrind",
    "container:valgrind:fetch": "node tools/aurora/native-debug.mjs valgrind-fetch",
    "demos:verify": "node tools/aurora/verify-demos.mjs",
    "compat:verify": "node tools/aurora/verify-compat.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:dev:full": "cross-env DOCS_AUDIENCE=full vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:build:full": "cross-env DOCS_AUDIENCE=full vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "gen-api-reference": "pnpm --filter @aurobore/build build && node packages/build/scripts/gen-api-reference.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "publish": "node scripts/check-npm-publish.mjs && pnpm build && pnpm changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aurobore-platform/aurora.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "cross-env": "^7.0.3",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.3",
    "vitest": "^2.1.8"
  }
}
