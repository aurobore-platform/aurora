# Локальные пути для dev-toolkit PoC (скопируйте в local.env рядом с этим файлом).
# Файл local.env в .gitignore — не коммитьте машинно-специфичные пути.

# Каталог bin Aurora SDK (sfdk.exe). Если sfdk уже в PATH — можно не задавать.
# AURORA_SDK_BIN=C:\AuroraOS\bin

# Таргет сборки mb2/sfdk
SFDK_TARGET=AuroraOS-5.2.1.200-x86_64

# Куда синхронизировать PoC перед сборкой (должен быть виден Docker build engine).
# Windows: обычно %USERPROFILE%\aurobore-spike\poc-bridge
# Linux/macOS: ~/aurobore-spike/poc-bridge
# POC_BUILD_DIR=%USERPROFILE%\aurobore-spike\poc-bridge

# SSH к эмулятору
EMULATOR_SSH_USER=defaultuser
EMULATOR_SSH_HOST=127.0.0.1
EMULATOR_SSH_PORT=2223
EMULATOR_SSH_KEY=C:\AuroraOS\vmshare\ssh\private_keys\sdk

# Таймаут ожидания загрузки эмулятора (секунды)
EMULATOR_BOOT_TIMEOUT=300

# Пауза после холодного старта эмулятора, когда SSH уже есть, но GUI/Wayland ещё поднимается
EMULATOR_WARMUP_SEC=15

# Ожидание «PoC OK» в journal после запуска приложения (секунды)
POC_RUN_WAIT_SEC=60

# CEF remote debugging (chrome://inspect). Раскомментируйте для container:run;
# поднимите SSH-туннель вручную: ssh -i ... -N -L 9222:127.0.0.1:9222 -p 2223 defaultuser@127.0.0.1
# AUROBORE_CEF_DEBUG_PORT=9222

# Verbose Qt logs при container:run (см. docs/dev/native-debugging.md)
# AUROBORE_QT_LOGGING_RULES=*.debug=false;aurobore.*.debug=true

# W3 spike: после loopback load перейти на первый origin из web.allowedOrigins
# AUROBORE_W3_EXTERNAL=1

# Доп. флаги Valgrind для pnpm container:valgrind
# VALGRIND_OPTS=--leak-check=full --show-leak-kinds=all --track-origins=yes

# Имя RPM после сборки (glob относительно POC_BUILD_DIR/RPMS)
POC_RPM_GLOB=ru.auroraos.poc-bridge-*.rpm
